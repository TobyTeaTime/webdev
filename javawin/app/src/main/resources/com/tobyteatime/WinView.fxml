<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<!-- a node in the scene graph-->

<AnchorPane fx:id="anchorPane" onMouseEntered="#handleMouseHover" prefHeight="480.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tobyteatime.WinController">
<!--Child nodes are indexed from edges of anchor pane, extends pane extends node expects children styled with CSS-->
    <children>
        <Button fx:id="button" layoutX="370.0" layoutY="128.0" onAction="#handleButtonAction" text="Click Me">
         <font>
            <Font name="Courier New" size="18.0" />
         </font></Button>
        <Label fx:id="label" alignment="CENTER" layoutX="391.0" layoutY="217.0" minHeight="16" minWidth="69">
         <font>
            <Font name="Courier New" size="18.0" />
         </font></Label>
    </children>
</AnchorPane>
